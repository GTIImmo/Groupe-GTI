SMTP_HOST=smtp.exemple.fr
SMTP_PORT=587
SMTP_USER=compte-smtp@exemple.fr
SMTP_PASS=mot-de-passe-smtp
SMTP_SECURE=false

# Expediteur technique par defaut si le SMTP n'autorise pas un from libre.
SMTP_FROM=diffusion@exemple.fr

# Mettre a true uniquement si votre SMTP autorise l'utilisateur de l'app
# comme expediteur direct.
SMTP_ALLOW_USER_FROM=false

# Optionnel : secours si le parametre Supabase app_setting.appointment_email_logo_url
# n'est pas encore present.
APPOINTMENT_EMAIL_LOGO_URL=https://gtiimmo.github.io/vitrine/rdv/gti-logo.png

# Cle serveur Supabase necessaire pour l'outil admin de creation utilisateur.
SUPABASE_SERVICE_ROLE_KEY=

# URL de l'app pour les redirections d'email de reinitialisation.
APP_BASE_URL=http://localhost:5173
